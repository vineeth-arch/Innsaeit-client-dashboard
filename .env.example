# Innsaeit Client Dashboard — environment variables.
# Frontend vars (VITE_*) are bundled into the client; everything else is
# server-only and must be set in the Vercel project's environment settings.

# ---- Frontend (Vite; safe to expose — RLS enforces access) ----
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# ---- Serverless (/api) ----
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...   # service role: bypasses RLS, NEVER expose to the client

# Cloudflare R2 file storage (S3-compatible; see api/_lib/r2.js). App-level
# credentials — all R2 calls happen server-side, never in the browser.
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET=...

# ---- Email digests (all optional: when unset, email is silently skipped and
# ---- the app is unaffected) ----
RESEND_API_KEY=re_...
# Sender. Must be on a Resend-verified domain for real delivery. When unset we
# fall back to onboarding@resend.dev, which ONLY delivers to the Resend account
# owner's own inbox — fine for testing, useless for real recipients.
NOTIFY_FROM="Design Innsaeit <tracker@designinnsaeit.com>"
# CTA target ("Open tracker") in every email.
APP_URL=https://your-deployment.vercel.app
# TEST_MODE: when "true", EVERY email (digest cron + live compliance-approved)
# is redirected to TEST_MODE_RECIPIENT only — all other recipients (supervisor,
# buyers, checkers) are silently dropped (logged as "[TEST_MODE] Suppressed
# send to ..."). Content is identical; only the To field changes. Unset/"false"
# = normal production sending. If TEST_MODE=true but TEST_MODE_RECIPIENT is
# empty, sends are suppressed entirely (never delivered to real recipients).
TEST_MODE=false
TEST_MODE_RECIPIENT=you@example.com
# Vercel Cron sends "Authorization: Bearer $CRON_SECRET" to cron routes when
# this is set; the same header authorizes manual POST test triggers.
CRON_SECRET=<long-random-string>
