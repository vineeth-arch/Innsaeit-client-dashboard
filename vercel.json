{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/daily-digest", "schedule": "30 4 * * *" }
  ],
  "functions": {
    "api/cron/daily-digest.js": { "maxDuration": 60 }
  }
}
